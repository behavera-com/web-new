# Slack notifications (optional)
WEBHOOK_URL=https://hooks.slack.com/services/XXXX/YYYY/ZZZZ

# SendGrid — required for LP startupjobs emails
# 1) Vytvor API key v https://app.sendgrid.com/settings/api_keys (Restricted, "Mail Send" full)
# 2) Verify "hello@behavera.com" jako Sender (Single Sender nebo Domain Authentication)
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SENDGRID_FROM_EMAIL=hello@behavera.com
SENDGRID_FROM_NAME=Behavera

# Pipedrive — required for LP startupjobs leads
# Token: Settings → Personal preferences → API
# Domain: subdomena ve tvem Pipedrive URL (https://<DOMAIN>.pipedrive.com)
PIPEDRIVE_API_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
PIPEDRIVE_DOMAIN=behavera

# Origin URL pro obrázky v auto-reply emailech (loga, fotky reps, behavera logo).
# Default: https://new-behavera.vercel.app — přepnout na startupjobs.behavera.com až bude live.
EMAIL_ASSETS_URL=https://new-behavera.vercel.app

# ── First-party cookieless analytika (LP startupjobs) ───────────────────────
# Úložiště eventů se vybírá dle priority v src/lib/tracking/store.ts:
#   1) Upstash Redis (proměnné níže)  2) Blueboard most (default v kódu)
#   3) lokální .analytics-data/ (dev). Nic z toho není nutné pro běh webu —
#   bez nastavení se použije most, analytika nikdy neshodí stránku.
#
# PRODUKCE: Vercel → Storage → Create Database → Upstash Redis (Free, EU).
# Propojení s projektem propíše URL + TOKEN automaticky.
UPSTASH_REDIS_REST_URL=https://xxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Salt pro týdně rotující anonymní hash návštěvníka (žádná surová IP se neukládá).
# Vygeneruj: openssl rand -hex 24 — v produkci NUTNÉ nastavit (default je v kódu).
ANALYTICS_SALT=

# Heslo do dashboardu /api/stats. Default v kódu je "behast2026" — v produkci přepiš.
ANALYTICS_STATS_KEY=

# Volitelné — přepis cíle/secretu Blueboard mostu (jinak defaulty z kódu).
# ANALYTICS_REMOTE_URL=https://katalogodpadu.cz/api/behavera-ingest.php
# ANALYTICS_REMOTE_SECRET=
# ANALYTICS_REMOTE=1   # vynutí most i mimo produkci (lokální ověření)
